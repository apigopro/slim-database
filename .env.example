# Copy this file to .env and fill in real values.
# .env itself must NEVER be committed — only this .example file is.
#
# IMPORTANT: pick exactly ONE driver section below (PostgreSQL, MySQL, or
# Oracle) and uncomment only that one. DB_DNS and DB_ENCODING must only be
# set ONCE — if you copy more than one block active at the same time, only
# the last DB_DNS/DB_ENCODING in the file wins and the others are silently
# ignored (dotenv does not merge repeated keys, later simply overwrites
# earlier).

# --- Shared across all drivers ---
DB_HOST="127.0.0.1"
DB_PORT="5432"
DB_NAME="myapp"
DB_AUTH_USER=""
DB_AUTH_PASSWORD=""
DB_APP_USER=""
DB_APP_PASSWORD=""
DB_TIMEZONE="Europe/Sarajevo"
DB_PERSISTENT="false"

# --- PostgreSQL (uncomment this block, comment out MySQL/Oracle) ---
DB_DNS="pgsql:host=%s;port=%d;dbname=%s"
DB_ENCODING="UTF8"

# --- MySQL / MariaDB ---
# DB_PORT="3306"
# DB_DNS="mysql:host=%s;port=%d;dbname=%s"
# DB_ENCODING="UTF8MB4"
# DB_COLLATION="UTF8MB4_GENERAL_CI"
# DB_AUTOCOMMIT="true"
#
# NOTE: named timezones (like the DB_TIMEZONE above) require MySQL's time
# zone tables to be populated once per server — see README "MySQL named
# timezones" section. Without that step, connecting fails with
# "Unknown or incorrect time zone" even though everything else is correct.

# --- Oracle ---
# See README "Oracle setup" for Instant Client + pdo_oci installation —
# this is the one driver here that cannot be installed via a simple
# apt/pecl command, Oracle requires a licensed manual download.
#
# TNS="(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=%s)(PORT=%d))(CONNECT_DATA=(SERVER=DEDICATED)(SERVICE_NAME=%s)))"
# DB_PORT="1521"
# DB_ENCODING="AL32UTF8"
# DB_DNS="oci:dbname=${TNS};charset=${DB_ENCODING}"
# DB_AUTOCOMMIT="true"
#
# NOTE: Oracle's charset named literally "UTF8" is NOT the same as full
# Unicode UTF-8 — it's an older, subtly incomplete encoding. Use
# "AL32UTF8" for real UTF-8 behavior. This is a well-known Oracle gotcha,
# not a typo.
